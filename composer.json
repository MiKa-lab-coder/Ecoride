{
  "name": "ecoride/webapp",
  "description": "Ecoride web application",
  "type": "project-graduate",
  "require" :{
    "php":">= 8.2",
    "nikic/fast-route": "^v1.3.0",
    "vlucas/phpdotenv": "^5.5",
    "mongodb/mongodb": "^2.1",
    "ext-pdo": "*",
    "monolog/monolog": "^3.9",
    "ext-mbstring": "*",
    "firebase/php-jwt": "^6.11",
    "phpmailer/phpmailer": "^6.10",
    "ext-mongodb": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload":{
    "psr-4": {
      "App\\":"src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "tests\\": "tests/"
    }
  }
}
